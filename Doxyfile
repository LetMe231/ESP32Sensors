PROJECT_NAME           = "BLE Mesh Multi-Sensor Server"
PROJECT_BRIEF          = "ESP32-S3 BLE Mesh vendor server with SGP30, AHT20, and MAX30101 sensors"
OUTPUT_DIRECTORY       = ./doxygen
CREATE_SUBDIRS         = NO
INPUT                  = main src
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.c *.h
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */test/*
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_EXTRA_STYLESHEET  =
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

HAVE_DOT               = YES
DOT_PATH               = "C:\Program Files\Graphviz\bin"
CLASS_DIAGRAMS         = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
SHOW_USED_FILES        = YES
SHOW_FILES             = YES
UML_LOOK               = YES
UML_LIMIT_NUM_FIELDS   = 10
TEMPLATE_RELATIONS     = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 50
MAX_DOT_GRAPH_DEPTH    = 0
DOT_CLEANUP            = YES
COLLABORATION_GRAPH    = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES

WARN_IF_UNDOCUMENTED   = YES
WARN_IF_UNDOC_MEMBER   = YES
WARN_NO_PARAMDOC       = NO
WARN_FORMAT            = "$file:$line: $text"
QUIET                  = NO
